# ═══════════════════════════════════════════════
# MetalMaster ERP — Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git!
# ═══════════════════════════════════════════════

# Firebase Configuration (required)
# Get these from Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Sentry Error Tracking (optional, recommended for production)
# Get DSN from https://sentry.io → Project Settings → Client Keys
# VITE_SENTRY_DSN=https://xxx@o000000.ingest.sentry.io/0000000

# Super Admin Emails (comma-separated, case-insensitive)
# These users bypass all permission checks
VITE_SUPER_ADMIN_EMAILS=admin@example.com

# Firebase App Check — reCAPTCHA Enterprise (optional, recommended for production)
# Protects Firebase APIs from unauthorized access.
# Get the site key from: Google Cloud Console → reCAPTCHA Enterprise → Create Key
# Then register it in Firebase Console → App Check → Apps → your web app
# VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=your_site_key_here
